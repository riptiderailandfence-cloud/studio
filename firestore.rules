
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * PILLARPATH SECURITY RULES
     */

    // --- HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Checks if the user's profile document links them to this tenant.
    function isTenantMember(tenantId) {
      return isSignedIn() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tenantId == tenantId;
    }

    // Fallback: Checks if the user is the explicit owner of the tenant document.
    // This is useful during initialization before the User profile is fully indexed.
    function isTenantOwner(tenantId) {
      return isSignedIn() && 
             get(/databases/$(database)/documents/tenants/$(tenantId)).data.ownerUserId == request.auth.uid;
    }

    function hasRole(tenantId, roles) {
      return isTenantMember(tenantId) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in roles;
    }

    function matchesPathTenant(tenantId) {
      return request.resource.data.tenantId == tenantId;
    }

    function tenantIdImmutable() {
      return request.resource.data.tenantId == resource.data.tenantId;
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false;
    }

    match /tenants/{tenantId} {
      // Allow access if they are a profile-linked member OR the explicit owner.
      allow get: if isSignedIn() && (
        isTenantMember(tenantId) || 
        isTenantOwner(tenantId) ||
        (resource != null && resource.data.ownerUserId == request.auth.uid)
      );
      allow list: if false;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        isTenantOwner(tenantId) ||
        hasRole(tenantId, ['Owner', 'Admin'])
      );
      allow delete: if false; 
    }

    match /tenants/{tenantId}/settings/general {
      allow get: if isSignedIn() && (isTenantMember(tenantId) || isTenantOwner(tenantId));
      allow list: if false;
      allow create: if isSignedIn(); 
      allow update: if isSignedIn() && (isTenantMember(tenantId) || isTenantOwner(tenantId)) && tenantIdImmutable();
      allow delete: if false;
    }

    match /tenants/{tenantId}/customers/{customerId} {
      allow get, list: if isTenantMember(tenantId) || isTenantOwner(tenantId);
      allow create: if (isTenantMember(tenantId) || isTenantOwner(tenantId)) && matchesPathTenant(tenantId);
      allow update: if (isTenantMember(tenantId) || isTenantOwner(tenantId)) && tenantIdImmutable();
      allow delete: if hasRole(tenantId, ['Owner', 'Admin']) || isTenantOwner(tenantId);
    }

    match /tenants/{tenantId}/materials/{materialId} {
      allow get, list: if isTenantMember(tenantId) || isTenantOwner(tenantId);
      allow create: if (isTenantMember(tenantId) || isTenantOwner(tenantId)) && matchesPathTenant(tenantId);
      allow update: if (isTenantMember(tenantId) || isTenantOwner(tenantId)) && tenantIdImmutable();
      allow delete: if hasRole(tenantId, ['Owner', 'Admin']) || isTenantOwner(tenantId);
    }

    match /tenants/{tenantId}/fenceStyles/{styleId} {
      allow get, list: if isTenantMember(tenantId) || isTenantOwner(tenantId);
      allow create: if (isTenantMember(tenantId) || isTenantOwner(tenantId)) && matchesPathTenant(tenantId);
      allow update: if (isTenantMember(tenantId) || isTenantOwner(tenantId)) && tenantIdImmutable();
      allow delete: if hasRole(tenantId, ['Owner', 'Admin']) || isTenantOwner(tenantId);
    }

    match /tenants/{tenantId}/postStyles/{styleId} {
      allow get, list: if isTenantMember(tenantId) || isTenantOwner(tenantId);
      allow create: if (isTenantMember(tenantId) || isTenantOwner(tenantId)) && matchesPathTenant(tenantId);
      allow update: if (isTenantMember(tenantId) || isTenantOwner(tenantId)) && tenantIdImmutable();
      allow delete: if hasRole(tenantId, ['Owner', 'Admin']) || isTenantOwner(tenantId);
    }

    match /tenants/{tenantId}/gateStyles/{styleId} {
      allow get, list: if isTenantMember(tenantId) || isTenantOwner(tenantId);
      allow create: if (isTenantMember(tenantId) || isTenantOwner(tenantId)) && matchesPathTenant(tenantId);
      allow update: if (isTenantMember(tenantId) || isTenantOwner(tenantId)) && tenantIdImmutable();
      allow delete: if hasRole(tenantId, ['Owner', 'Admin']) || isTenantOwner(tenantId);
    }

    match /tenants/{tenantId}/estimates/{estimateId} {
      allow get: if isTenantMember(tenantId) || isTenantOwner(tenantId) || (resource != null && request.auth == null); 
      allow list: if isTenantMember(tenantId) || isTenantOwner(tenantId);
      allow create: if (isTenantMember(tenantId) || isTenantOwner(tenantId)) && matchesPathTenant(tenantId);
      allow update: if (isTenantMember(tenantId) || isTenantOwner(tenantId)) && tenantIdImmutable();
      allow delete: if hasRole(tenantId, ['Owner', 'Admin']) || isTenantOwner(tenantId);
    }

    match /tenants/{tenantId}/crewMembers/{memberId} {
      allow get, list: if isTenantMember(tenantId) || isTenantOwner(tenantId);
      allow create: if (isTenantMember(tenantId) || isTenantOwner(tenantId)) && matchesPathTenant(tenantId);
      allow update: if (isTenantMember(tenantId) || isTenantOwner(tenantId)) && tenantIdImmutable();
      allow delete: if hasRole(tenantId, ['Owner', 'Admin']) || isTenantOwner(tenantId);
    }

    match /tenants/{tenantId}/crews/{crewId} {
      allow get, list: if isTenantMember(tenantId) || isTenantOwner(tenantId);
      allow create: if (isTenantMember(tenantId) || isTenantOwner(tenantId)) && matchesPathTenant(tenantId);
      allow update: if (isTenantMember(tenantId) || isTenantOwner(tenantId)) && tenantIdImmutable();
      allow delete: if hasRole(tenantId, ['Owner', 'Admin']) || isTenantOwner(tenantId);
    }

    match /tenants/{tenantId}/jobs/{jobId} {
      allow get, list: if isTenantMember(tenantId) || isTenantOwner(tenantId);
      allow create: if (isTenantMember(tenantId) || isTenantOwner(tenantId)) && matchesPathTenant(tenantId);
      allow update: if (isTenantMember(tenantId) || isTenantOwner(tenantId)) && tenantIdImmutable();
      allow delete: if hasRole(tenantId, ['Owner', 'Admin']) || isTenantOwner(tenantId);
    }

    match /tenants/{tenantId}/chats/{chatId} {
      allow read: if isTenantMember(tenantId) || isTenantOwner(tenantId);
      allow create: if (isTenantMember(tenantId) || isTenantOwner(tenantId)) && matchesPathTenant(tenantId);
      allow update: if (isTenantMember(tenantId) || isTenantOwner(tenantId)) && tenantIdImmutable();
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isTenantMember(tenantId) || isTenantOwner(tenantId);
        allow create: if isTenantMember(tenantId) || isTenantOwner(tenantId) || (request.resource.data.senderId == 'client');
        allow update, delete: if false;
      }
    }
  }
}
