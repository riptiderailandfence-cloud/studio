
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * PILLARPATH SECURITY RULES
     */

    // --- HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Direct check against the user's own profile doc. 
    // Does NOT recurse into tenant checks.
    function isTenantMember(tenantId) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tenantId == tenantId;
    }

    function currentUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(tenantId, roles) {
      return isTenantMember(tenantId) && currentUserData().role in roles;
    }

    function matchesPathTenant(tenantId) {
      return request.resource.data.tenantId == tenantId;
    }

    function tenantIdImmutable() {
      return request.resource.data.tenantId == resource.data.tenantId;
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false;
    }

    match /tenants/{tenantId} {
      // Allow the owner to read the tenant doc even before the User profile is fully indexed
      allow get: if isSignedIn() && (
        isTenantMember(tenantId) || 
        (resource != null && resource.data.ownerUserId == request.auth.uid)
      );
      allow list: if false;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        hasRole(tenantId, ['Owner', 'Admin']) ||
        (resource != null && resource.data.ownerUserId == request.auth.uid)
      );
      allow delete: if false; 
    }

    match /tenants/{tenantId}/settings/general {
      // Allow get if they are a member OR if they own the parent tenant
      allow get: if isSignedIn() && (
        isTenantMember(tenantId) ||
        get(/databases/$(database)/documents/tenants/$(tenantId)).data.ownerUserId == request.auth.uid
      );
      allow list: if isTenantMember(tenantId);
      allow create: if isSignedIn(); 
      allow update: if isSignedIn() && (
        hasRole(tenantId, ['Owner', 'Admin']) ||
        get(/databases/$(database)/documents/tenants/$(tenantId)).data.ownerUserId == request.auth.uid
      ) && tenantIdImmutable();
      allow delete: if false;
    }

    match /tenants/{tenantId}/customers/{customerId} {
      allow get, list: if isTenantMember(tenantId);
      allow create: if isTenantMember(tenantId) && !hasRole(tenantId, ['Crew Member']) && matchesPathTenant(tenantId);
      allow update: if isTenantMember(tenantId) && !hasRole(tenantId, ['Crew Member']) && tenantIdImmutable();
      allow delete: if isTenantMember(tenantId) && hasRole(tenantId, ['Owner', 'Admin']);
    }

    match /tenants/{tenantId}/materials/{materialId} {
      allow get, list: if isTenantMember(tenantId);
      allow create: if isTenantMember(tenantId) && hasRole(tenantId, ['Owner', 'Admin', 'Estimator']) && matchesPathTenant(tenantId);
      allow update: if isTenantMember(tenantId) && hasRole(tenantId, ['Owner', 'Admin', 'Estimator']) && tenantIdImmutable();
      allow delete: if isTenantMember(tenantId) && hasRole(tenantId, ['Owner', 'Admin']);
    }

    match /tenants/{tenantId}/fenceStyles/{styleId} {
      allow get, list: if isTenantMember(tenantId);
      allow create: if isTenantMember(tenantId) && hasRole(tenantId, ['Owner', 'Admin', 'Estimator']) && matchesPathTenant(tenantId);
      allow update: if isTenantMember(tenantId) && hasRole(tenantId, ['Owner', 'Admin', 'Estimator']) && tenantIdImmutable();
      allow delete: if isTenantMember(tenantId) && hasRole(tenantId, ['Owner', 'Admin']);
    }

    match /tenants/{tenantId}/postStyles/{styleId} {
      allow get, list: if isTenantMember(tenantId);
      allow create: if isTenantMember(tenantId) && hasRole(tenantId, ['Owner', 'Admin', 'Estimator']) && matchesPathTenant(tenantId);
      allow update: if isTenantMember(tenantId) && hasRole(tenantId, ['Owner', 'Admin', 'Estimator']) && tenantIdImmutable();
      allow delete: if isTenantMember(tenantId) && hasRole(tenantId, ['Owner', 'Admin']);
    }

    match /tenants/{tenantId}/gateStyles/{styleId} {
      allow get, list: if isTenantMember(tenantId);
      allow create: if isTenantMember(tenantId) && hasRole(tenantId, ['Owner', 'Admin', 'Estimator']) && matchesPathTenant(tenantId);
      allow update: if isTenantMember(tenantId) && hasRole(tenantId, ['Owner', 'Admin', 'Estimator']) && tenantIdImmutable();
      allow delete: if isTenantMember(tenantId) && hasRole(tenantId, ['Owner', 'Admin']);
    }

    match /tenants/{tenantId}/estimates/{estimateId} {
      allow get: if isTenantMember(tenantId) || (resource != null && request.auth == null); 
      allow list: if isTenantMember(tenantId);
      allow create: if isTenantMember(tenantId) && hasRole(tenantId, ['Owner', 'Admin', 'Estimator']) && matchesPathTenant(tenantId);
      allow update: if isTenantMember(tenantId) && hasRole(tenantId, ['Owner', 'Admin', 'Estimator']) && tenantIdImmutable();
      allow delete: if isTenantMember(tenantId) && hasRole(tenantId, ['Owner', 'Admin']);
    }

    match /tenants/{tenantId}/crewMembers/{memberId} {
      allow get, list: if isTenantMember(tenantId);
      allow create: if isTenantMember(tenantId) && hasRole(tenantId, ['Owner', 'Admin', 'Crew Manager']) && matchesPathTenant(tenantId);
      allow update: if isTenantMember(tenantId) && hasRole(tenantId, ['Owner', 'Admin', 'Crew Manager']) && tenantIdImmutable();
      allow delete: if isTenantMember(tenantId) && hasRole(tenantId, ['Owner', 'Admin']);
    }

    match /tenants/{tenantId}/crews/{crewId} {
      allow get, list: if isTenantMember(tenantId);
      allow create: if isTenantMember(tenantId) && hasRole(tenantId, ['Owner', 'Admin', 'Crew Manager']) && matchesPathTenant(tenantId);
      allow update: if isTenantMember(tenantId) && hasRole(tenantId, ['Owner', 'Admin', 'Crew Manager']) && tenantIdImmutable();
      allow delete: if isTenantMember(tenantId) && hasRole(tenantId, ['Owner', 'Admin']);
    }

    match /tenants/{tenantId}/jobs/{jobId} {
      allow get, list: if isTenantMember(tenantId);
      allow create: if isTenantMember(tenantId) && !hasRole(tenantId, ['Crew Member']) && matchesPathTenant(tenantId);
      allow update: if isTenantMember(tenantId) && matchesPathTenant(tenantId) && tenantIdImmutable();
      allow delete: if isTenantMember(tenantId) && hasRole(tenantId, ['Owner', 'Admin']);
    }

    // Rules for Chat Threads
    match /tenants/{tenantId}/chats/{chatId} {
      allow read: if isTenantMember(tenantId);
      allow create: if isTenantMember(tenantId) && matchesPathTenant(tenantId);
      allow update: if isTenantMember(tenantId) && tenantIdImmutable();
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isTenantMember(tenantId);
        allow create: if isTenantMember(tenantId) || (request.resource.data.senderId == 'client');
        allow update, delete: if false;
      }
    }
  }
}
