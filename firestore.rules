
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Direct check for business ownership
    function isTenantOwner(tenantId) {
      // Deterministic check for the primary owner
      return isSignedIn() && (
        request.auth.uid == tenantId || 
        (exists(/databases/$(database)/documents/tenants/$(tenantId)) && 
         get(/databases/$(database)/documents/tenants/$(tenantId)).data.ownerUserId == request.auth.uid)
      );
    }

    // Check if user is a member of the tenant via their profile
    function isTenantMember(tenantId) {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tenantId == tenantId;
    }

    function matchesPathTenant(tenantId) {
      return request.resource.data.tenantId == tenantId;
    }

    function tenantIdImmutable() {
      return !("tenantId" in resource.data) || request.resource.data.tenantId == resource.data.tenantId;
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create, update: if isOwner(userId);
      allow list, delete: if false;
    }

    match /tenants/{tenantId} {
      allow get: if isSignedIn() && (
        request.auth.uid == tenantId || 
        (resource != null && resource.data.ownerUserId == request.auth.uid) || 
        isTenantMember(tenantId)
      );
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (request.auth.uid == tenantId || resource.data.ownerUserId == request.auth.uid);
      allow list, delete: if false; 
    }

    match /tenants/{tenantId}/settings/general {
      allow get: if isSignedIn() && (isTenantOwner(tenantId) || isTenantMember(tenantId));
      allow create: if isSignedIn() && matchesPathTenant(tenantId); 
      allow update: if isSignedIn() && (isTenantOwner(tenantId) || isTenantMember(tenantId)) && tenantIdImmutable();
      allow list, delete: if false;
    }

    match /tenants/{tenantId}/{collectionName}/{docId} {
      allow read: if isSignedIn() && (isTenantOwner(tenantId) || isTenantMember(tenantId));
      allow create: if isSignedIn() && (isTenantOwner(tenantId) || isTenantMember(tenantId)) && matchesPathTenant(tenantId);
      allow update: if isSignedIn() && (isTenantOwner(tenantId) || isTenantMember(tenantId)) && tenantIdImmutable();
      allow delete: if isSignedIn() && isTenantOwner(tenantId);
    }

    match /tenants/{tenantId}/chats/{chatId} {
      allow read: if isSignedIn() && (isTenantOwner(tenantId) || isTenantMember(tenantId));
      allow create: if isSignedIn() && (isTenantOwner(tenantId) || isTenantMember(tenantId)) && matchesPathTenant(tenantId);
      allow update: if isSignedIn() && (isTenantOwner(tenantId) || isTenantMember(tenantId)) && tenantIdImmutable();
      
      match /messages/{messageId} {
        allow read: if isSignedIn() && (isTenantOwner(tenantId) || isTenantMember(tenantId));
        allow create: if isSignedIn() || (request.resource.data.senderId == 'client');
      }
    }
  }
}
