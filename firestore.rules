
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Direct check if user is a member of the tenant via their profile
    function isTenantMember(tenantId) {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return isSignedIn() && userDoc.tenantId == tenantId;
    }

    // Secondary check for workspace owners (using the deterministic ID or owner field)
    function isTenantOwner(tenantId) {
      return isSignedIn() && (request.auth.uid == tenantId || 
        get(/databases/$(database)/documents/tenants/$(tenantId)).data.ownerUserId == request.auth.uid);
    }

    function matchesPathTenant(tenantId) {
      return request.resource.data.tenantId == tenantId;
    }

    function tenantIdImmutable() {
      return request.resource.data.tenantId == resource.data.tenantId;
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create, update: if isOwner(userId);
      allow list, delete: if false;
    }

    match /tenants/{tenantId} {
      allow get: if isSignedIn() && (isTenantMember(tenantId) || isTenantOwner(tenantId));
      allow create: if isSignedIn();
      allow update: if isTenantOwner(tenantId);
      allow list, delete: if false; 
    }

    match /tenants/{tenantId}/settings/general {
      allow get: if isSignedIn() && (isTenantMember(tenantId) || isTenantOwner(tenantId));
      allow create: if isSignedIn(); 
      allow update: if isSignedIn() && (isTenantMember(tenantId) || isTenantOwner(tenantId)) && tenantIdImmutable();
      allow list, delete: if false;
    }

    match /tenants/{tenantId}/{collectionName}/{docId} {
      allow read: if isSignedIn() && (isTenantMember(tenantId) || isTenantOwner(tenantId));
      allow create: if isSignedIn() && (isTenantMember(tenantId) || isTenantOwner(tenantId)) && matchesPathTenant(tenantId);
      allow update: if isSignedIn() && (isTenantMember(tenantId) || isTenantOwner(tenantId)) && tenantIdImmutable();
      allow delete: if isSignedIn() && isTenantOwner(tenantId);
    }

    match /tenants/{tenantId}/chats/{chatId} {
      allow read: if isSignedIn() && (isTenantMember(tenantId) || isTenantOwner(tenantId));
      allow create: if isSignedIn() && (isTenantMember(tenantId) || isTenantOwner(tenantId)) && matchesPathTenant(tenantId);
      allow update: if isSignedIn() && (isTenantMember(tenantId) || isTenantOwner(tenantId)) && tenantIdImmutable();
      
      match /messages/{messageId} {
        allow read: if isSignedIn() && (isTenantMember(tenantId) || isTenantOwner(tenantId));
        allow create: if isSignedIn() || (request.resource.data.senderId == 'client');
      }
    }
  }
}
