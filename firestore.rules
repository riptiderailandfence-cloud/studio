
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Direct check if user is a member of the tenant via their profile
    function isTenantMember(tenantId) {
      // Safely fetch the user's profile which contains their tenantId.
      // This is not recursive because the 'users' collection rules are independent.
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return isSignedIn() && userDoc != null && userDoc.tenantId == tenantId;
    }

    // Secondary check for workspace owners. 
    // We use a deterministic check first (UID == tenantId) to avoid expensive lookups.
    function isTenantOwner(tenantId) {
      return isSignedIn() && (
        request.auth.uid == tenantId || 
        get(/databases/$(database)/documents/tenants/$(tenantId)).data.ownerUserId == request.auth.uid
      );
    }

    function matchesPathTenant(tenantId) {
      return request.resource.data.tenantId == tenantId;
    }

    function tenantIdImmutable() {
      // request.resource.data represents the document as it would exist after the update
      return request.resource.data.tenantId == resource.data.tenantId;
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create, update: if isOwner(userId);
      allow list, delete: if false;
    }

    match /tenants/{tenantId} {
      // We use 'resource.data' instead of isTenantOwner() to avoid recursion 
      // when accessing the tenant document itself.
      allow get: if isSignedIn() && (
        request.auth.uid == tenantId || 
        resource.data.ownerUserId == request.auth.uid || 
        isTenantMember(tenantId)
      );
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (request.auth.uid == tenantId || resource.data.ownerUserId == request.auth.uid);
      allow list, delete: if false; 
    }

    match /tenants/{tenantId}/settings/general {
      allow get: if isSignedIn() && (isTenantOwner(tenantId) || isTenantMember(tenantId));
      allow create: if isSignedIn(); 
      allow update: if isSignedIn() && (isTenantOwner(tenantId) || isTenantMember(tenantId)) && tenantIdImmutable();
      allow list, delete: if false;
    }

    match /tenants/{tenantId}/{collectionName}/{docId} {
      allow read: if isSignedIn() && (isTenantOwner(tenantId) || isTenantMember(tenantId));
      allow create: if isSignedIn() && (isTenantOwner(tenantId) || isTenantMember(tenantId)) && matchesPathTenant(tenantId);
      allow update: if isSignedIn() && (isTenantOwner(tenantId) || isTenantMember(tenantId)) && tenantIdImmutable();
      allow delete: if isSignedIn() && isTenantOwner(tenantId);
    }

    match /tenants/{tenantId}/chats/{chatId} {
      allow read: if isSignedIn() && (isTenantOwner(tenantId) || isTenantMember(tenantId));
      allow create: if isSignedIn() && (isTenantOwner(tenantId) || isTenantMember(tenantId)) && matchesPathTenant(tenantId);
      allow update: if isSignedIn() && (isTenantOwner(tenantId) || isTenantMember(tenantId)) && tenantIdImmutable();
      
      match /messages/{messageId} {
        allow read: if isSignedIn() && (isTenantOwner(tenantId) || isTenantMember(tenantId));
        allow create: if isSignedIn() || (request.resource.data.senderId == 'client');
      }
    }
  }
}
